[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude = .venv,venv,.git,__pycache__,docs,scripts/deprecated,archive_local

# Tests intentionally import local scripts after manipulating sys.path.
# Keep per-file-ignores minimal: only ignore dynamic test reimport issues and
# unused temporary locals; E402 and E501 should be fixed in tests instead.
per-file-ignores =
    tests/*: F811,F841
